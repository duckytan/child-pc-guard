<Window x:Class="ChildPCGuard.AdminPanel.Views.LoginWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="ChildPCGuard - 管理员登录" Height="300" Width="400"
        WindowStartupLocation="CenterScreen" ResizeMode="NoModal"
        Background="#F0F0F0">

    <Window.Resources>
        <Style TargetType="Button">
            <Setter Property="Padding" Value="10,8"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="Margin" Value="0,0,5,0"/>
        </Style>
        <Style TargetType="PasswordBox">
            <Setter Property="Padding" Value="8"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
        </Style>
    </Window.Resources>

    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- 标题 -->
        <TextBlock Grid.Row="0" Text="管理员登录" FontSize="24" FontWeight="Bold"
                   HorizontalAlignment="Center" Margin="0,0,0,30"/>

        <!-- 状态提示（锁定倒计时） -->
        <TextBlock Grid.Row="1" x:Name="StatusText" Foreground="Orange"
                   HorizontalAlignment="Center" Margin="0,0,0,15"
                   Visibility="Collapsed"/>

        <!-- 密码输入 -->
        <Grid Grid.Row="2" Margin="0,0,0,20">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <TextBlock Grid.Column="0" Text="密码：" VerticalAlignment="Center"
                       FontSize="14" Margin="0,0,10,0"/>

            <PasswordBox Grid.Column="1" x:Name="PasswordBox"
                        PasswordChanged="PasswordBox_PasswordChanged"
                        KeyDown="PasswordBox_KeyDown"/>
        </Grid>

        <!-- 错误提示 -->
        <TextBlock Grid.Row="3" x:Name="ErrorText" Foreground="Red"
                   HorizontalAlignment="Center" Margin="0,0,0,20"
                   Visibility="Collapsed" FontSize="12"/>

        <!-- 按钮 -->
        <StackPanel Grid.Row="4" Orientation="Horizontal" HorizontalAlignment="Center">
            <Button Content="登录" x:Name="LoginButton" Click="Login_Click"
                    Width="100" IsDefault="True" IsEnabled="False"/>
            <Button Content="取消" Click="Cancel_Click" Width="100" IsCancel="True"/>
        </StackPanel>
    </Grid>
</Window>
