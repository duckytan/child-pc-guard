<Window x:Class="ChildPCGuard.AdminPanel.Views.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="ChildPCGuard 管理面板" Height="600" Width="900"
        WindowStartupLocation="CenterScreen">

    <Window.Resources>
        <Style TargetType="Button">
            <Setter Property="Padding" Value="10,6"/>
            <Setter Property="Margin" Value="0,0,5,0"/>
            <Setter Property="FontSize" Value="12"/>
        </Style>
        <Style TargetType="TextBox">
            <Setter Property="Padding" Value="5"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
        </Style>
        <Style TargetType="TextBlock">
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
        </Style>
    </Window.Resources>

    <Grid Margin="10">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="200"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <!-- 左侧导航 -->
        <Border Grid.Column="0" Background="#E0E0E0" Padding="10" Margin="0,0,10,0">
            <StackPanel>
                <TextBlock Text="导航" FontWeight="Bold" FontSize="16" Margin="0,0,0,15"/>

                <Button Content="首页/状态" Click="NavigateToStatus" Margin="0,0,0,5"/>
                <Button Content="规则设置" Click="NavigateToRules" Margin="0,0,0,5"/>
                <Button Content="临时操作" Click="NavigateToActions" Margin="0,0,0,5"/>
                <Button Content="日志查看" Click="NavigateToLogs" Margin="0,0,0,5"/>
                <Button Content="密码修改" Click="NavigateToPassword" Margin="0,0,0,5"/>
                <Button Content="关于" Click="NavigateToAbout" Margin="0,0,0,5"/>

                <Separator Margin="0,15,0,15"/>

                <Button Content="退出" Click="Exit_Click" Background="#FFE0E0" Foreground="Red"/>
            </StackPanel>
        </Border>

        <!-- 右侧内容区 -->
        <Frame Grid.Column="1" x:Name="ContentFrame" NavigationUIVisibility="Hidden"/>
    </Grid>
</Window>
