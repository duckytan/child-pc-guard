<Window x:Class="ChildPCGuard.LockOverlay.LockWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="电脑已锁定"
        WindowStyle="None"
        ResizeMode="NoResize"
        WindowState="Maximized"
        Topmost="True"
        Background="#1A1A2E"
        ShowInTaskbar="False">

    <Window.Resources>
        <Style TargetType="TextBlock">
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="FontSize" Value="16"/>
            <Setter Property="FontFamily" Value="Segoe UI, Microsoft YaHei"/>
            <Setter Property="HorizontalAlignment" Value="Center"/>
            <Setter Property="TextAlignment" Value="Center"/>
        </Style>

        <Style TargetType="TextBox">
            <Setter Property="FontSize" Value="20"/>
            <Setter Property="FontFamily" Value="Consolas"/>
            <Setter Property="HorizontalAlignment" Value="Center"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
            <Setter Property="Width" Value="250"/>
            <Setter Property="Height" Value="40"/>
            <Setter Property="TextAlignment" Value="Center"/>
            <Setter Property="MaxLength" Value="20"/>
        </Style>

        <Style TargetType="Button">
            <Setter Property="FontSize" Value="16"/>
            <Setter Property="FontFamily" Value="Segoe UI"/>
            <Setter Property="Padding" Value="30,10"/>
            <Setter Property="Margin" Value="0,20,0,0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="#4A90E2"
                                CornerRadius="5"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center"
                                          VerticalAlignment="Center"
                                          TextElement.Foreground="White"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="2*"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- 锁屏原因和时间 -->
        <StackPanel Grid.Row="0" VerticalAlignment="Center">
            <TextBlock x:Name="LockReasonText" FontSize="28" FontWeight="Bold" Margin="0,0,0,30"/>
            <TextBlock x:Name="CurrentTimeText" FontSize="48" FontWeight="Bold" Margin="0,20"/>
            <TextBlock x:Name="DateText" FontSize="18" Opacity="0.8"/>
        </StackPanel>

        <!-- 密码输入 -->
        <StackPanel Grid.Row="1" VerticalAlignment="Center">
            <TextBlock Text="请输入管理员密码解锁" Margin="0,0,0,20"/>
            <PasswordBox x:Name="PasswordInput"
                       KeyDown="PasswordInput_KeyDown"
                       FontSize="20"
                       FontFamily="Consolas"
                       Width="250"
                       Height="40"
                       HorizontalAlignment="Center"
                       VerticalAlignment="Center"
                       TextAlignment="Center"/>
        </StackPanel>

        <!-- 状态消息 -->
        <StackPanel Grid.Row="2" VerticalAlignment="Center">
            <TextBlock x:Name="StatusMessage"
                       Foreground="#FF6B6B"
                       FontSize="16"
                       Visibility="Collapsed"
                       Margin="0,10"/>
        </StackPanel>

        <!-- 解锁按钮 -->
        <StackPanel Grid.Row="3" VerticalAlignment="Center">
            <Button x:Name="UnlockButton"
                     Content="解锁"
                     Click="UnlockButton_Click"
                     IsDefault="True"/>
        </StackPanel>
    </Grid>
</Window>
